<Window x:Class="Chess2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chess2"
        mc:Ignorable="d"
        Title="Chess Knights"
        Height="850"
        Width="750"
        >
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    
    <DockPanel>

        <Button Content="Start / Reload"
                Height="40"
                DockPanel.Dock="Top"
                Click="Reload_Click"/>

        <ItemsControl ItemsSource="{Binding Cells}">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="8" Columns="8"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <Button Click="Cell_Click"
                            Background="{Binding Background}"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0"
                            Tag="{Binding}">

                        <Grid>
                            <!-- Подсветка выбранного -->
                            <Border BorderBrush="Yellow"
                                    BorderThickness="3"
                                    Visibility="{Binding IsSelected,
                                    Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- Фигура -->
                            <TextBlock Text="{Binding PieceSymbol}"
                                       FontSize="38"
                                       FontFamily="Segoe UI Symbol"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/> 

                            <!-- Зелёный круг -->
                            <Ellipse Width="18"
                                     Height="18"
                                     Fill="LimeGreen"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">

                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Marker}"
                                     Value="Valid">
                                                <Setter Property="Visibility"
                                    Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>

                            </Ellipse>

                                <!-- Красный / зелёный крест -->
                                <TextBlock Text="✖"
               FontSize="26"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">

                                            <Setter Property="Visibility"
                        Value="Collapsed"/>

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding Marker}"
                                 Value="Dangerous">
                                                    <Setter Property="Visibility"
                                Value="Visible"/>
                                                    <Setter Property="Foreground"
                                Value="Red"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Marker}"
                                 Value="Friendly">
                                                    <Setter Property="Visibility"
                                Value="Visible"/>
                                                    <Setter Property="Foreground"
                                Value="LimeGreen"/>
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </TextBlock.Style>

                                </TextBlock>

                            </Grid>

                    </Button>

                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </DockPanel>
    
</Window>
